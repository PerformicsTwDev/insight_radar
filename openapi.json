{
  "components": {
    "schemas": {
      "CreateKeywordAnalysisDto": {
        "properties": {
          "geo": {
            "description": "Google Ads geo target（國別）",
            "example": "TW",
            "type": "string"
          },
          "includeAdult": {
            "example": false,
            "type": "boolean"
          },
          "language": {
            "description": "語言",
            "example": "zh-TW",
            "type": "string"
          },
          "mode": {
            "enum": [
              "expand",
              "exact"
            ],
            "example": "expand",
            "type": "string"
          },
          "network": {
            "enum": [
              "GOOGLE_SEARCH",
              "GOOGLE_SEARCH_AND_PARTNERS"
            ],
            "example": "GOOGLE_SEARCH",
            "type": "string"
          },
          "seeds": {
            "example": [
              "running shoes",
              "trail shoes"
            ],
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "seeds",
          "geo",
          "language"
        ],
        "type": "object"
      },
      "CreateTopicRunDto": {
        "properties": {},
        "type": "object"
      },
      "QueryDto": {
        "properties": {},
        "type": "object"
      },
      "SseCompletedEventDto": {
        "properties": {
          "count": {
            "example": 1980,
            "nullable": true,
            "type": "number"
          },
          "resultSnapshotId": {
            "description": "結果 snapshot id（partial 亦以此收尾）",
            "example": "6f…uuid",
            "nullable": true,
            "type": "string"
          }
        },
        "required": [
          "resultSnapshotId",
          "count"
        ],
        "type": "object"
      },
      "SseFailedEventDto": {
        "properties": {
          "error": {
            "description": "失敗理由（已 scrubSecrets 遮罩）",
            "example": "RESOURCE_EXHAUSTED after 5 retries",
            "type": "string"
          }
        },
        "required": [
          "error"
        ],
        "type": "object"
      },
      "SseProgressEventDto": {
        "properties": {
          "expanded": {
            "example": 1980,
            "type": "number"
          },
          "labeled": {
            "example": 1420,
            "type": "number"
          },
          "percent": {
            "example": 72,
            "maximum": 100,
            "minimum": 0,
            "type": "number"
          },
          "phase": {
            "description": "目前階段（expand/intent/persist…）",
            "example": "intent",
            "type": "string"
          },
          "total": {
            "example": 1980,
            "type": "number"
          }
        },
        "required": [
          "phase",
          "percent"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "x-api-key": {
        "in": "header",
        "name": "x-api-key",
        "type": "apiKey"
      }
    }
  },
  "info": {
    "contact": {},
