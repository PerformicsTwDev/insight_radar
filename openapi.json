{
  "components": {
    "schemas": {
      "AddMembersDto": {
        "properties": {
          "items": {
            "description": "成員項（關鍵字列 / 主題列）",
            "items": {
              "$ref": "#/components/schemas/MemberItemDto"
            },
            "type": "array"
          }
        },
        "required": [
          "items"
        ],
        "type": "object"
      },
      "AiInsightDto": {
        "properties": {
          "filters": {
            "allOf": [
              {
                "$ref": "#/components/schemas/FilterSpecDto"
              }
            ],
            "description": "套用於該 view 的篩選（共用 /query 的 FilterSpec；聚合僅由 (view, filters) 決定，AC-32.2）"
          },
          "view": {
            "description": "要總結的 view（view-router 白名單，如 keywords / journey / journey_funnel / custom:{cid}）",
            "example": "keywords",
            "type": "string"
          }
        },
        "required": [
          "view"
        ],
        "type": "object"
      },
      "BrandEntryDto": {
        "properties": {
          "aliases": {
            "description": "別名/縮寫/拼寫變體（正規化聯集比對用，FR-40）；缺省 []",
            "example": [
              "華碩",
              "Asus"
            ],
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "name": {
            "description": "品牌名稱（本品牌同 owner 內唯一）",
            "example": "ASUS",
            "type": "string"
          },
          "sites": {
            "description": "官網 domain（citations 命中用，FR-43）；缺省 []",
            "example": [
              "asus.com"
            ],
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "name"
        ],
        "type": "object"
      },
      "CaptureIngestDto": {
        "properties": {
          "channel": {
            "description": "AI 渠道（AI 類帶；S20）",
            "enum": [
              "chatGpt",
              "geminiApp",
              "googleAiMode",
              "googleSearch",
              "aiOverview",
              "aiMode",
              "bingCopilot"
            ],
            "type": "string"
          },
          "items": {
            "description": "該來源原始 payload 陣列（raw，逐筆落 captures.payload JSONB）",
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array"
          },
          "platform": {
            "description": "Social 平台（Social 類帶；S20）",
            "enum": [
              "threads",
              "facebook",
              "dcard",
              "ptt",
              "customDomain"
            ],
            "type": "string"
          },
          "schemaVersion": {
            "description": "schemaVersion 必帶（S15）；allowlist 比對於 T13.3",
            "type": "string"
          },
          "source": {
            "description": "push 來源（extension=primary；serpapi/threadsApi=reserved）",
            "enum": [
              "extension",
              "serpapi",
              "threadsApi"
            ],
            "type": "string"
          }
        },
        "required": [
          "source",
          "schemaVersion",
          "items"
        ],
        "type": "object"
      },
      "CreateAiSearchAnalysisDto": {
        "properties": {
          "brandProfileId": {
            "description": "品牌檔案（FR-40）；供 M15 可見度分析，本抓取層僅記錄關聯",
            "format": "uuid",
            "type": "string"
          },
          "channels": {
            "description": "AI 渠道（extension primary / serpapi reserved，S20）；某渠道缺→partial",
            "example": [
              "chatGpt",
              "googleAiMode"
            ],
            "items": {
              "enum": [
                "chatGpt",
                "geminiApp",
                "googleAiMode",
                "googleSearch",
                "aiOverview",
                "aiMode",
                "bingCopilot"
              ],
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "keywords": {
            "example": [
              "asus zenbook",
              "macbook air"
            ],
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "keywords",
          "channels"
        ],
        "type": "object"
      },
      "CreateBrandProfileDto": {
        "properties": {
          "brand": {
            "allOf": [
              {
                "$ref": "#/components/schemas/BrandEntryDto"
              }
            ],
            "description": "本品牌（name + aliases + sites）"
          },
          "competitors": {
            "description": "競品清單（各 name + aliases + sites）；缺省 []",
            "items": {
              "$ref": "#/components/schemas/BrandEntryDto"
            },
            "type": "array"
          }
        },
        "required": [
          "brand"
        ],
        "type": "object"
      },
      "CreateKeywordAnalysisDto": {
        "properties": {
          "geo": {
            "description": "Google Ads geo target（國別）",
            "example": "TW",
            "type": "string"
          },
          "includeAdult": {
            "example": false,
            "type": "boolean"
          },
          "language": {
            "description": "語言",
            "example": "zh-TW",
            "type": "string"
          },
          "mode": {
            "enum": [
              "expand",
              "exact"
            ],
            "example": "expand",
            "type": "string"
          },
          "network": {
            "enum": [
              "GOOGLE_SEARCH",
              "GOOGLE_SEARCH_AND_PARTNERS"
            ],
            "example": "GOOGLE_SEARCH",
            "type": "string"
          },
          "seeds": {
            "example": [
              "running shoes",
              "trail shoes"
            ],
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "seeds",
          "geo",
          "language"
        ],
        "type": "object"
      },
      "CreateTopicRunDto": {
        "properties": {},
        "type": "object"
      },
      "CreateTrackingListDto": {
        "properties": {
          "geo": {
            "description": "Google Ads geo target（清單層固定）",
            "example": "TW",
            "type": "string"
          },
          "language": {
            "description": "語言（清單層固定）",
            "example": "zh-TW",
            "type": "string"
          },
          "name": {
            "description": "追蹤清單名稱（同 owner 內唯一）",
            "example": "Running shoes",
            "type": "string"
          }
        },
        "required": [
          "name",
          "geo",
          "language"
        ],
        "type": "object"
      },
      "CustomClassifyAssignDto": {
        "properties": {},
        "type": "object"
      },
      "CustomClassifyDto": {
        "properties": {},
        "type": "object"
      },
      "FilterSpecDto": {
        "properties": {},
        "type": "object"
      },
      "IdeationDto": {
        "properties": {},
        "type": "object"
      },
      "LoginDto": {
        "properties": {
          "email": {
            "example": "user@example.com",
            "format": "email",
            "maxLength": 254,
            "type": "string"
          },
          "password": {
            "example": "correct-horse-battery",
            "maxLength": 1024,
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "type": "object"
      },
      "MemberItemDto": {
        "properties": {
          "analysisId": {
            "description": "主題來源分析 id（kind=topic 必填）",
            "type": "string"
          },
          "geo": {
            "description": "該關鍵字來源分析的 geo 語境（kind=keyword 必填）",
            "type": "string"
          },
          "kind": {
            "description": "成員項判別：關鍵字列 / 主題列",
            "enum": [
              "keyword",
              "topic"
            ],
            "type": "string"
          },
          "language": {
            "description": "該關鍵字來源分析的 language 語境（kind=keyword 必填）",
            "type": "string"
          },
          "text": {
            "description": "關鍵字原字（kind=keyword 必填）；normalizedText 由伺服器導出",
            "type": "string"
          },
          "topicName": {
            "description": "主題名稱（kind=topic 必填）；展開為該分析最新 run 該群非-noise 關鍵字",
            "type": "string"
          }
        },
        "required": [
          "kind"
        ],
        "type": "object"
      },
      "QueryDto": {
        "properties": {},
        "type": "object"
      },
      "RegisterDto": {
        "properties": {
          "email": {
            "example": "user@example.com",
            "format": "email",
            "maxLength": 254,
            "type": "string"
          },
          "password": {
            "example": "correct-horse-battery",
            "maxLength": 1024,
            "minLength": 10,
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "type": "object"
      },
      "RenameTrackingListDto": {
        "properties": {
          "name": {
            "description": "新清單名稱（同 owner 內唯一）",
            "example": "Trail shoes",
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "type": "object"
      },
      "SseCompletedEventDto": {
        "properties": {
          "count": {
            "example": 1980,
            "nullable": true,
            "type": "number"
          },
          "resultSnapshotId": {
            "description": "結果 snapshot id（partial 亦以此收尾）",
            "example": "6f…uuid",
            "nullable": true,
            "type": "string"
          }
        },
        "required": [
          "resultSnapshotId",
          "count"
        ],
        "type": "object"
      },
      "SseFailedEventDto": {
        "properties": {
          "error": {
            "description": "失敗理由（已 scrubSecrets 遮罩）",
            "example": "RESOURCE_EXHAUSTED after 5 retries",
            "type": "string"
          }
        },
        "required": [
          "error"
        ],
        "type": "object"
      },
      "SseProgressEventDto": {
        "properties": {
          "expanded": {
            "example": 1980,
            "type": "number"
          },
          "labeled": {
            "example": 1420,
            "type": "number"
          },
          "percent": {
            "example": 72,
            "maximum": 100,
            "minimum": 0,
            "type": "number"
          },
          "phase": {
            "description": "目前階段（expand/intent/persist…）",
            "example": "intent",
            "type": "string"
          },
          "total": {
            "example": 1980,
            "type": "number"
          }
        },
        "required": [
          "phase",
          "percent"
        ],
        "type": "object"
      },
      "UpdateBrandProfileDto": {
        "properties": {
          "aliases": {
            "description": "本品牌別名（整組取代）",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "competitors": {
            "description": "競品清單（整組取代）",
            "items": {
              "$ref": "#/components/schemas/BrandEntryDto"
            },
            "type": "array"
          },
          "name": {
            "description": "本品牌新名稱（同 owner 內唯一）",
            "example": "ASUS",
            "type": "string"
          },
          "sites": {
            "description": "本品牌官網 domain（整組取代）",
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      }
    },
    "securitySchemes": {
      "x-api-key": {
        "in": "header",
        "name": "x-api-key",
        "type": "apiKey"
      }
    }
  },
  "info": {
    "contact": {},
    "description": "關鍵字分析 dashboard 後端 API（業務路由掛 /api/v1，/health 除外）",
    "title": "insight_radar_v3 API",
    "version": "1"
  },
  "openapi": "3.0.0",
