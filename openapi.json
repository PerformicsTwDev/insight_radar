    "/api/v1/keyword-analyses/{id}/ai-insight": {
      "post": {
        "operationId": "AiInsightController_generate",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AiInsightDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "{ view, insight, generatedAt }"
          },
          "400": {
            "description": "未知 view / 非 UUID id / 未宣告欄位（whitelist forbidNonWhitelisted）"
          },
          "404": {
            "description": "未知或非 owner 的 analysis（owner 過濾單點 S8）"
          },
          "409": {
            "description": "snapshot 未就緒 / feature 未 ready"
          },
          "502": {
            "description": "AI_INSIGHT_GENERATION_FAILED（LLM 失敗，不回半截摘要）"
          }
        },
        "summary": "per-view AI 洞察（同步 200；LLM 失敗 → 502）",
        "tags": [
          "ai-insight"
        ]
      }
    },
    "/api/v1/keyword-analyses/{id}/custom-classifications": {
      "post": {
        "operationId": "CustomClassifyController_create",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
