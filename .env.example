# committed，無祕密；新人入口（複製成本機 .env 後填值）。
# 所有 ✅ 必填變數缺值或格式錯 → ConfigModule Joi 啟動 fail-fast（TC-19）。

# === Core ===
NODE_ENV=development
API_KEY=                              # x-api-key 比對值（FR-11）
API_PREFIX=api/v1                     # 業務路由前綴（/health 除外，NFR-10）
ALLOWED_ORIGINS=                      # CORS 白名單（逗號分隔 origin；空=不允許跨域），NFR-14；credentials 模式不可 '*'
SSE_HEARTBEAT_MS=15000                # SSE heartbeat 事件週期（ms），FR-9；防 LB/proxy idle 切斷
HELMET_ENABLED=true                  # helmet 安全 header 開關（NFR-14；預設開，非 production 可關）
BODY_LIMIT_MB=5                       # JSON body 上限（MB），NFR-14；自 express 100kb 預設提高（exact 模式大 seeds），逾此→413
# —— Auth（M10，FR-24/NFR-15）——
ARGON2_MEMORY_KIB=19456               # argon2id 記憶體成本（KiB），OWASP 下限 19 MiB；過低=弱雜湊（S7）
ARGON2_TIME_COST=2                    # argon2id 迭代數（time cost）
ARGON2_PARALLELISM=1                  # argon2id 並行度
AUTH_MIN_PASSWORD_LEN=10               # 密碼最小長度（弱密碼→驗證錯）
SESSION_SECRET=                       # ★ redact（NFR-15）；session 祕密（≥16 字，reserved：opaque sid 不簽章，ADR-0006），Joi fail-fast
SESSION_TTL_MS=604800000              # Redis session TTL（ms），7 天
SESSION_COOKIE_NAME=sid               # session cookie 名稱
SESSION_COOKIE_SECURE=true            # 非 test 預設 true（漏設即降級，S6/NFR-15）
SESSION_COOKIE_SAMESITE=lax           # CSRF 雙層之一（FR-26）
PORT=3000
LOG_LEVEL=info                        # pino level：trace|debug|info|warn|error|fatal|silent

# === Google Ads（六項憑證，啟動 Joi 驗證 / AC-11.4）===
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=             # ★ redact（TC-29）
GOOGLE_ADS_REFRESH_TOKEN=            # ★ redact（TC-29）
GOOGLE_ADS_DEVELOPER_TOKEN=         # ★ redact（TC-29）
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=               # 目標 CID（per-CID 節流 key，TC-16）
GOOGLE_ADS_SEED_BATCH_SIZE=15         # 硬上限 20（絕不送出 >20）
GOOGLE_ADS_HISTORICAL_BATCH_SIZE=1000 # 硬上限 10000
GOOGLE_ADS_QPS=1                      # per-CID ~QPS（AdsRateLimiter minTime=ceil(1000/QPS)）
GOOGLE_ADS_MAX_RETRIES=5              # job 內 Ads 暫時性錯誤就地退避重試上限（≠ JOB_ATTEMPTS）
GOOGLE_ADS_BACKOFF_BASE_MS=5000       # Ads 退避起始延遲（5s→10s→20s + jitter）

# === Azure OpenAI ===
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=                 # ★ redact（TC-29）
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21   # 必在 allowlist 內（非字典序 >=）；建議 2024-10-21 / v1
AZURE_OPENAI_MAX_RETRIES=5
LLM_BATCH_SIZE=30
LLM_CONCURRENCY=6

# === Infra ===
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://user:pass@localhost:5432/insight_radar
CACHE_TTL_METRICS_MS=1814400000       # ★ TTL 毫秒（21 天）
CACHE_TTL_INTENT_MS=5184000000        # ★ TTL 毫秒（60 天）
INTENT_SCHEMA_VERSION=v1              # intent 快取 namespace 版本；bump（如 v2）即整批失效（schema/prompt 變更時）
AI_INSIGHT_SCHEMA_VERSION=v1          # per-view AI 洞察快取 namespace 版本（FR-32/AC-32.2）；bump 整批失效
CACHE_TTL_AI_INSIGHT_MS=5184000000    # ★ per-view AI 洞察快取 TTL 毫秒（60 天；內容綁不可變 snapshot，TTL 僅記憶體逐出）
AI_INSIGHT_MAX_ROWS=200               # table-grain view 洞察有界代表樣本上限（top-N by volume，M12-R2/AC-32.1）
JOURNEY_SCHEMA_VERSION=v1             # 購買歷程分類快取 namespace 版本（FR-33/AC-33.3）；bump 整批失效（schema/prompt 變更時）
CACHE_TTL_JOURNEY_MS=5184000000       # ★ 購買歷程分類 Redis 快取 TTL 毫秒（60 天；綁 normalizedText+版本，TTL 僅記憶體逐出）
JOURNEY_LLM_BATCH_SIZE=30             # 購買歷程每 prompt 關鍵字數（沿用 intent 批量慣例；並發沿用 LLM_CONCURRENCY）
JOURNEY_MAX_KEYWORDS=5000             # 購買歷程 async job 單次分類關鍵字數上限（成本護欄，超過→413；#484）
JOURNEY_QUEUE_CONCURRENCY=3           # 購買歷程 worker 並發（BullMQ；同 topics 慣例）
CUSTOM_CLASSIFY_MAX_LABELS=12         # 自訂分類標籤數上限（動態 enum 大小，AC-34.1）
CUSTOM_CLASSIFY_SCHEMA_VERSION=v1     # 自訂分類 schema/快取版本（階段二歸類快取，FR-34）
CUSTOM_CLASSIFY_LLM_BATCH_SIZE=30     # 自訂分類每 prompt 關鍵字數（沿用 intent/journey 批量慣例；並發沿用 LLM_CONCURRENCY）
CUSTOM_CLASSIFY_MAX_KEYWORDS=5000     # 自訂分類 async job 單次歸類關鍵字數上限（成本護欄，超過→413；FR-34）
IDEATION_MAX_KEYWORDS=50              # AI 發想去重後回傳關鍵字數上限（FR-35）
CUSTOM_CLASSIFY_QUEUE_CONCURRENCY=3   # 自訂分類 worker 並發（BullMQ；同 topics/journey 慣例）
CACHE_TTL_CUSTOM_CLASSIFY_MS=5184000000  # ★ 自訂分類階段二歸類 Redis 快取 TTL 毫秒（60 天；綁 normalizedText+版本，TTL 僅記憶體逐出）
WORKER_CONCURRENCY=5
JOB_ATTEMPTS=5                         # BullMQ job-level 重試次數（僅暫時性基礎設施故障；Ads 配額由 job 內退避）
JOB_BACKOFF_MS=3000                    # 重試指數退避起始延遲（ms，2^(n-1)*delay）
JOB_BACKOFF_JITTER=0.2                 # 退避 jitter 比例 0..1（散開重試、避免 thundering herd，NFR-9）
IDEMP_TTL_MS=86400000                 # 1 天（ms）
JOB_TTL_MS=259200000                  # ★ TTL 毫秒（3 天）：`job:{id}` 狀態摘要快取存活
QUERY_MAX_PAGE_SIZE=200                # /query 與 /keywords 單頁上限（超出 → 400）
AGG_MAX_BUCKETS=200
AGG_MAX_GROUPS=1000

# === Embeddings（M8）===
GEMINI_API_KEY=                        # ★ redact（NFR-5）；@google/genai client 憑證
GEMINI_EMBEDDING_DIM=3072              # 固定 3072（= halfvec(3072) 欄）；768/1536 為未來增強（需 vector 型別 migration）
GEMINI_EMBEDDING_MODEL=gemini-embedding-001   # 鎖此 id
GEMINI_EMBEDDING_TASK_TYPE=CLUSTERING
GEMINI_EMBEDDING_BATCH_SIZE=100        # 硬上限 500（>500 有順序 bug）
GEMINI_EMBEDDING_CONCURRENCY=4         # 批次並發（p-limit）
GEMINI_EMBEDDING_MAX_RETRIES=5         # 429/5xx/傳輸層退避重試上限
GEMINI_EMBEDDING_BACKOFF_BASE_MS=500   # 退避起始延遲（ms，2^(n-1)*base）
EMBEDDING_SCHEMA_VERSION=v1            # embedding 快取 namespace；bump（v2…）整批失效
CACHE_TTL_EMBEDDING_MS=5184000000      # ★ TTL 毫秒（60 天）

# === SERP（M8；MVP 預設關閉→純文字 embedding）===
SERP_ENABLED=false                     # true 時 SERP_PROVIDER/API_KEY/API_URL 變必填
SERP_PROVIDER=serpapi                  # serpapi | serper
SERP_API_KEY=                          # ★ redact（NFR-5）；SERP_ENABLED=true 時必填
SERP_API_URL=                          # 供應商端點；SERP_ENABLED=true 時必填
SERP_TOP_N=5                           # 取前 N 筆 organic
SERP_FRESHNESS_DAYS=30                 # durable serp_fetches 重用新鮮窗（窗內不重抓）
# SERP_RETENTION_DAYS=                 # 未設＝保留全部歷史（SERP-over-time）
SERP_MAX_RETRIES=3                     # 429/5xx/傳輸層退避重試上限
SERP_BACKOFF_BASE_MS=500               # 退避起始延遲（ms，2^(n-1)*base）

# === SerpAPI AI adapters（M14；FR-38，reserved 預設關；憑證沿用 SERP_API_KEY/URL）===
SERPAPI_AI_ENABLED=false               # AI adapters master 開關（reserved；主管道＝extension 橋接 FR-39）
SERPAPI_AI_MODE_ENABLED=false          # google_ai_mode engine per-engine 開關（AC-38.3；須連同 master 皆開）
SERPAPI_BING_COPILOT_ENABLED=false     # bing_copilot engine（AC-38.4，could，預設關）
SERPAPI_AIO_PAGE_TOKEN_TIMEOUT_MS=50000  # AI Overview page_token 二次抓取時限（ms，<60000 過期裕度）
SERPAPI_AI_CREDITS_BUDGET=1000         # 每 job SerpAPI credit 預算（AIO 二次抓取最多 2 credits/query）
SERPAPI_AI_HL=zh-tw                    # AI 抓取語言（AC-38.5）
SERPAPI_AI_GL=tw                       # AI 抓取地區（AC-38.5）
AI_SEARCH_QUEUE_CONCURRENCY=3          # AI Search 抓取 job BullMQ worker 並發（T14.6；同 topics/journey）

# === Clustering（M8；HTTP → Python cluster-service）===
CLUSTER_SERVICE_URL=http://localhost:8000  # ✅ 必填；topics 分群呼叫 POST {url}/cluster
CLUSTER_SERVICE_TIMEOUT_MS=90000       # 單次請求逾時（CPU-bound UMAP+HDBSCAN 需長 timeout）
CLUSTER_SERVICE_RETRIES=2              # 逾時/5xx/傳輸層退避重試上限（達上限 → job 標 partial）
CLUSTER_SERVICE_BACKOFF_BASE_MS=1000  # 退避起始延遲（ms，2^(n-1)*base）

# === Topics（M8；群命名複用 Azure LLM）===
TOPIC_LLM_BATCH_CLUSTERS=20            # 每批送 LLM 命名的群數
TOPIC_PROMPT_VERSION=v1                # 命名 prompt 版本；bump（v2…）令下游快取/紀錄失效
TOPIC_SCHEMA_VERSION=v1                # 命名 json_schema 版本；同上
TOPICS_QUEUE_CONCURRENCY=3             # topics BullMQ worker 並發

# === Tracking（M11，FR-28~30 / NFR-16；追蹤清單 + 搜量時序快照 + 排程刷新）===
# 上限直接治理每日 Ads 用量（見 docs/RUNBOOK.md「追蹤刷新 Ads 配額治理」）：每日刷新關鍵字數 ≈
# TRACKING_MAX_LISTS × TRACKING_MAX_MEMBERS_PER_LIST，串行 ~1 QPS/CID（沿用 AdsRateLimiter，不放大 QPS）。
TRACKING_MAX_LISTS=50                  # 每 owner 清單數上限（AC-28.7；建立超限→409）
TRACKING_MAX_MEMBERS_PER_LIST=500     # 每清單成員數上限（AC-28.7；加入超限→409）
TRACKING_MAX_ITEMS_PER_REQUEST=500    # 加成員單批 items 上限（NFR-16 DoS 前置守門；超→400）
TRACKING_BACKFILL_MONTHS=12           # 加入/刷新回填 monthlyVolumes 月數（AC-29.1；預設=Ads 原生窗）
TRACKING_REFRESH_CRON=0 3 * * *       # 排程刷新 repeatable job cron（AC-29.2；預設每日一次）；worker 並發固定 1（單飛，見 RUNBOOK）
TRACKING_KEEP_SERIES_ON_DELETE=false  # 刪清單時是否保留時序（AC-28.2；false=連帶刪 VolumeSnapshot、true=保留孤立快照）
TRACKING_SWEEP_LEASE_MS=3600000       # 排程 sweep DB 租約鎖 TTL（single-flight #470/NFR-16；crash 復原上界，須 ≥ 預期 sweep 時長）
# TRACKING_HISTORY_RETENTION_DAYS=    # reserved（未接線）：VolumeSnapshot 保留天數；預設不設=保留全部。定期 pruning / D1 分區為未來任務，目前無消費者故不啟用

# === Capture ingestion（M13，FR-36 / NFR-17；Design §14/§18.2；統一 POST /captures 落 raw append-only）===
INGEST_BATCH_MAX=500                   # POST /captures 單批 items 上限（AC-36.5 請求形狀守門；超→413，先於 contentHash/DB，防 DoS）
INGEST_BODY_LIMIT_MB=10               # POST /captures 獨立 body 上限（MB，AC-36.5）；AI 回答/貼文集可能大→高於全域 BODY_LIMIT_MB，端點掛專屬 body parser，逾此→413
CAPTURE_ACCEPTED_SCHEMA_VERSIONS=v1   # schemaVersion allowlist（逗號分隔，S15/AC-36.3）；缺/值不在清單→400（不猜形狀）；extension 現況＝v1
# extension bridge 能力協商基準（逗號分隔，S21/NFR-21/AC-51.4）；期望 EXTERNAL_PONG.features[] 應含之渠道，未回報→gating not-available（不硬崩/不編造）。現 confirmed 3（threadsSearch/googleSerp/chatGpt）+ 期望擴充（外部協調 T13.6）：
EXTENSION_BRIDGE_REQUIRED_FEATURES=threadsSearch,googleSerp,chatGpt,geminiApp,googleAiMode,googleSearch,facebook,dcard,ptt,readability
# CAPTURE_PAT_ENABLED=false           # reserved（v2/NG14，T13.8）：extension direct-push PAT 認證開關；本期不接線（Joi 已驗型別＋預設 false，無 runtime 消費者）。主管道＝前端代 push（session cookie）
# source / channel / platform allowlist 非 env：由 DTO const enum（src/captures/dto/capture-ingest.dto.ts 的 @IsIn + OpenAPI enum）＋ per-discriminator mapper registry 界定/強制（S20）；env-gating＝fake configurability（不在 enum 的值無 mapper），故不設 CAPTURE_ACCEPTED_SOURCES/CHANNELS/PLATFORMS
