# committed，dummy 但「格式合法」可通過 Joi/allowlist；CI 載入（NODE_ENV=test）。
# ⚠ 嚴禁放任何看似真的金鑰（即使過期）—— 違反 NFR-5 且 push protection 會擋（DevelopmentRules §14.3）。
NODE_ENV=test
PORT=3000
API_PREFIX=api/v1
API_KEY=test-api-key
ALLOWED_ORIGINS=http://localhost:5173   # CORS 白名單（逗號分隔）；e2e TC-58 用
SSE_HEARTBEAT_MS=15000                   # SSE heartbeat 週期（ms）
HELMET_ENABLED=true                      # helmet 安全 header 開關（NFR-14）；e2e TC-58 用
BODY_LIMIT_MB=1                          # 測試刻意收窄為 1（prod 預設 5）：讓 ~1.5MB 即逾限→413，免用 >5MB 大 payload（NFR-14, TC-58）
INGEST_BATCH_MAX=5                        # 測試收窄（prod 預設 500）：讓 6 筆即超批次上限→413，免送大批次（AC-36.5, TC-72）
INGEST_BODY_LIMIT_MB=2                    # 測試設 2（prod 預設 10）：> 全域 BODY_LIMIT_MB=1，證專屬 parser 放大生效；~2.5MB 即逾限→413（AC-36.5, TC-72）
CAPTURE_ACCEPTED_SCHEMA_VERSIONS=v1,v2    # schemaVersion allowlist（S15/AC-36.3）：測試收 v1,v2（e2e 用 v2）；v9 等不在清單→400（TC-72）
EXTENSION_BRIDGE_REQUIRED_FEATURES=threadsSearch,googleSerp,chatGpt,readability  # 能力協商基準（S21/NFR-21，TC-94）：測試取現 confirmed 3 + readability（擴充項）→ PONG 未回報 readability 時 gating not-available
ARGON2_MEMORY_KIB=19456                   # argon2id 記憶體成本（KiB，OWASP 下限 19 MiB）；M10 auth
ARGON2_TIME_COST=2                        # argon2id 迭代數
ARGON2_PARALLELISM=1                      # argon2id 並行度
AUTH_MIN_PASSWORD_LEN=10                   # 密碼最小長度（弱密碼→驗證錯）
SESSION_SECRET=test-session-secret-0123456789  # dummy（≥16 字）；session 簽章祕密
SESSION_TTL_MS=604800000                  # Redis session TTL（ms，7 天）
SESSION_COOKIE_NAME=sid
SESSION_COOKIE_SECURE=false               # 測試走 http → false（prod 預設 true，S6）
SESSION_COOKIE_SAMESITE=lax
GOOGLE_ADS_CLIENT_ID=test-client-id
GOOGLE_ADS_CLIENT_SECRET=test-client-secret
GOOGLE_ADS_REFRESH_TOKEN=test-refresh-token
GOOGLE_ADS_DEVELOPER_TOKEN=test-developer-token
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890
GOOGLE_ADS_CUSTOMER_ID=1234567890
AZURE_OPENAI_ENDPOINT=https://test.openai.azure.com
AZURE_OPENAI_API_KEY=test-azure-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21   # ★ 必在 allowlist，否則 boot fail（TC-19）
GEMINI_API_KEY=test-gemini-key        # @google/genai client（lazy，不真連）
REDIS_URL=redis://localhost:6379      # ioredis-mock 攔截，不連真實 Redis
DATABASE_URL=postgresql://test:test@localhost:5432/test  # integration/e2e 由 Testcontainers 覆寫
CLUSTER_SERVICE_URL=http://localhost:8000  # ✅ 必填；分群 client mock（不真連 Python 服務）
