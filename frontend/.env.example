# Frontend runtime configuration (Vite).
#
# Only `VITE_`-prefixed vars are exposed to the client bundle (import.meta.env).
# Copy this file to `.env.local` (git-ignored) for local dev. All vars below are
# OPTIONAL (defaults in src/config/env.ts, mirroring Design §14); a PROVIDED but
# invalid value (bad enum / non-numeric) fails-fast at boot.
#
# NEVER put secrets here: anything in a VITE_-prefixed var ships to the browser.
# (session auth is an httpOnly cookie, never in JS; x-api-key is user-entered →
# sessionStorage, never in .env / bundle.)

# API origin. '' = same-origin (client resolves to window.location.origin).
# openapi paths already carry /api/v1, so this is an ORIGIN, not a path prefix.
VITE_API_BASE_URL=
VITE_AUTH_PROVIDER=session          # session | apiKey
VITE_TREND_STABLE_MAX=5             # 穩定型上界（%，0≤%<5）
VITE_TREND_SURGE_MIN=20             # 爆發型下界（%，≥20）
VITE_DEFAULT_PAGE_SIZE=25
VITE_MAX_PAGE_SIZE=100              # 鏡射後端 QUERY_MAX_PAGE_SIZE
VITE_OFFSET_MAX_PAGE=40             # 超過此頁切 keyset（C5）
VITE_SSE_HEARTBEAT_TIMEOUT_MS=20000
VITE_SSE_RETRY_MS=3000
VITE_POLL_INTERVAL_MS=2000
VITE_VIRTUAL_ROW_THRESHOLD=100
VITE_TRACKING_DEFAULT_RANGE=12M     # 6M | 12M | all
VITE_TRACKING_CONTINUE_TOP_N=3      # home「從追蹤清單繼續」預設卡片數（T7.7）
VITE_AI_CHANNELS=AI Overview,AI Mode,Gemini,ChatGPT   # AI Search 抓取渠道選項（FR-23）
