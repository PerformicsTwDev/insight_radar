// 資料模型單一真實來源（Design §5.2）。表結構由 `prisma migrate` 產生；
// `pg_trgm` extension 與 GIN/trgm 索引為手動補進 migration（Prisma 不自動產生）。

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

enum JobStatus {
  queued
  running
  completed
  partial
  failed
  canceled
}

model KeywordAnalysis {
  id               String          @id @default(uuid()) @db.Uuid
  status           JobStatus
  seeds            Json
  params           Json
  progress         Json
  idempotencyKey   String          @unique @map("idempotency_key")
  resultSnapshot   ResultSnapshot? @relation(fields: [resultSnapshotId], references: [id])
  resultSnapshotId String?         @map("result_snapshot_id") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz
  startedAt        DateTime?       @map("started_at") @db.Timestamptz
  finishedAt       DateTime?       @map("finished_at") @db.Timestamptz
  error            String?

  @@index([status])
  @@map("keyword_analyses")
}

model ResultSnapshot {
  id           String            @id @default(uuid()) @db.Uuid
  analysisId   String            @map("keyword_analysis_id") @db.Uuid
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz
  keywordCount Int               @map("keyword_count")
  checksum     String
  rows         SnapshotRow[]
  analyses     KeywordAnalysis[]

  @@index([analysisId])
  @@map("result_snapshots")
}

model Keyword {
  normalizedText     String   @map("normalized_text")
  geo                String
  language           String
  text               String
  avgMonthlySearches Int?     @map("avg_monthly_searches")
  competition        String?
  competitionIndex   Int?     @map("competition_index")
  cpcLowMicros       BigInt?  @map("cpc_low_micros")
  cpcHighMicros      BigInt?  @map("cpc_high_micros")
  monthlyVolumes     Json     @default("[]") @map("monthly_volumes")
  currencyCode       String?  @map("currency_code")
  metricsFetchedAt   DateTime @default(now()) @map("metrics_fetched_at") @db.Timestamptz

  @@id([geo, language, normalizedText])
  @@map("keywords")
}

model KeywordIntent {
  normalizedText String   @map("normalized_text")
  modelVersion   String   @map("model_version")
  labels         Json
  labeledAt      DateTime @default(now()) @map("labeled_at") @db.Timestamptz

  @@id([normalizedText, modelVersion])
  @@map("keyword_intents")
}

model SnapshotRow {
  snapshot   ResultSnapshot @relation(fields: [snapshotId], references: [id])
  snapshotId String         @map("snapshot_id") @db.Uuid
  analysisId String         @map("keyword_analysis_id") @db.Uuid
  rowIndex   Int            @map("row_index")
  data       Json

  @@id([snapshotId, rowIndex])
  @@index([analysisId])
  @@map("snapshot_rows")
}

// keyword_embeddings（T8.1，Design §5.2，FR-16/NFR-13）：pgvector `embedding` 欄以 `Unsupported` 宣告
// （Prisma 不支援 vector 型別）；`CREATE EXTENSION vector` 與 HNSW `halfvec_cosine_ops` 索引走**手寫 migration**。
// gemini-embedding-001 原生 3072 已為單位長度 → 存 `halfvec(3072)` 免手動 normalize（halfvec ANN 上限 4000 ⊇ 3072）。
model KeywordEmbedding {
  normalizedText String                       @map("normalized_text")
  geo            String
  language       String
  model          String // gemini-embedding-001
  taskType       String                       @map("task_type") // CLUSTERING
  dim            Int // 3072（gemini 全維；= GEMINI_EMBEDDING_DIM）
  inputHash      String                       @map("input_hash") // 含是否帶 SERP（TC-39）
  embedding      Unsupported("halfvec(3072)") // 原生 3072 已 normalize（免手動）
  createdAt      DateTime                     @default(now()) @map("created_at") @db.Timestamptz

  @@id([geo, language, normalizedText, model, taskType, dim])
  @@map("keyword_embeddings")
}

// serp_fetches（T8.3，Design §5.2/§16，FR-15）：SERP 抓取的**持久層 SSOT**（非 TTL 快取）——每次抓取一列、
// append-only、保留歷史（供 freshness 窗重用 + SERP-over-time）。`results` 為中立形狀 `{ organic:[{position,
// title,url,snippet,domain}], paa?:[], related?:[] }`；`captured`/`raw` 為 Phase 2 / 重解析選配。
model SerpFetch {
  id             String   @id @default(uuid()) @db.Uuid
  normalizedText String   @map("normalized_text")
  keyword        String
  geo            String
  language       String
  device         String? // desktop|mobile（預設 desktop）
  provider       String // serpapi|serper|extension
  results        Json
  captured       Json? // Phase 2：extension 抓取的頁面內容
  raw            Json? // 選配：原始 payload，供日後重解析
  fetchedAt      DateTime @default(now()) @map("fetched_at") @db.Timestamptz

  @@index([geo, language, normalizedText, fetchedAt])
  @@map("serp_fetches")
}
