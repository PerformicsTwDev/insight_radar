// 資料模型單一真實來源（Design §5.2）。表結構由 `prisma migrate` 產生；
// `pg_trgm` extension 與 GIN/trgm 索引為手動補進 migration（Prisma 不自動產生）。

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

enum JobStatus {
  queued
  running
  completed
  partial
  failed
  canceled
}

model KeywordAnalysis {
  id               String          @id @default(uuid()) @db.Uuid
  status           JobStatus
  seeds            Json
  params           Json
  progress         Json
  idempotencyKey   String          @unique @map("idempotency_key")
  resultSnapshot   ResultSnapshot? @relation(fields: [resultSnapshotId], references: [id])
  resultSnapshotId String?         @map("result_snapshot_id") @db.Uuid
  ownerId          String?         @map("owner_id") @db.Uuid // FR-27：資源歸屬（session→user.id、apiKey→null）；nullable、不回填
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz
  startedAt        DateTime?       @map("started_at") @db.Timestamptz
  finishedAt       DateTime?       @map("finished_at") @db.Timestamptz
  error            String?

  @@index([status])
  @@index([ownerId]) // owner 過濾（歷史清單 where ownerId，FR-27）
  @@map("keyword_analyses")
}

model ResultSnapshot {
  id           String            @id @default(uuid()) @db.Uuid
  analysisId   String            @map("keyword_analysis_id") @db.Uuid
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz
  keywordCount Int               @map("keyword_count")
  checksum     String
  rows         SnapshotRow[]
  analyses     KeywordAnalysis[]

  @@index([analysisId])
  @@map("result_snapshots")
}

model Keyword {
  normalizedText     String   @map("normalized_text")
  geo                String
  language           String
  text               String
  avgMonthlySearches Int?     @map("avg_monthly_searches")
  competition        String?
  competitionIndex   Int?     @map("competition_index")
  cpcLowMicros       BigInt?  @map("cpc_low_micros")
  cpcHighMicros      BigInt?  @map("cpc_high_micros")
  monthlyVolumes     Json     @default("[]") @map("monthly_volumes")
  currencyCode       String?  @map("currency_code")
  metricsFetchedAt   DateTime @default(now()) @map("metrics_fetched_at") @db.Timestamptz

  @@id([geo, language, normalizedText])
  @@map("keywords")
}

model KeywordIntent {
  normalizedText String   @map("normalized_text")
  modelVersion   String   @map("model_version")
  labels         Json
  labeledAt      DateTime @default(now()) @map("labeled_at") @db.Timestamptz

  @@id([normalizedText, modelVersion])
  @@map("keyword_intents")
}

model SnapshotRow {
  snapshot   ResultSnapshot @relation(fields: [snapshotId], references: [id])
  snapshotId String         @map("snapshot_id") @db.Uuid
  analysisId String         @map("keyword_analysis_id") @db.Uuid
  rowIndex   Int            @map("row_index")
  data       Json

  @@id([snapshotId, rowIndex])
  @@index([analysisId])
  @@map("snapshot_rows")
}

// keyword_embeddings（T8.1，Design §5.2，FR-16/NFR-13）：pgvector `embedding` 欄以 `Unsupported` 宣告
// （Prisma 不支援 vector 型別）；`CREATE EXTENSION vector` 與 HNSW `halfvec_cosine_ops` 索引走**手寫 migration**。
// gemini-embedding-001 原生 3072 已為單位長度 → 存 `halfvec(3072)` 免手動 normalize（halfvec ANN 上限 4000 ⊇ 3072）。
model KeywordEmbedding {
  normalizedText String                       @map("normalized_text")
  geo            String
  language       String
  model          String // gemini-embedding-001
  taskType       String                       @map("task_type") // CLUSTERING
  dim            Int // 3072（gemini 全維；= GEMINI_EMBEDDING_DIM）
  inputHash      String                       @map("input_hash") // 含是否帶 SERP（TC-39）
  embedding      Unsupported("halfvec(3072)") // 原生 3072 已 normalize（免手動）
  createdAt      DateTime                     @default(now()) @map("created_at") @db.Timestamptz

  @@id([geo, language, normalizedText, model, taskType, dim])
  @@map("keyword_embeddings")
}

// serp_fetches（T8.3，Design §5.2/§16，FR-15）：SERP 抓取的**持久層 SSOT**（非 TTL 快取）——每次抓取一列、
// append-only、保留歷史（供 freshness 窗重用 + SERP-over-time）。`results` 為中立形狀 `{ organic:[{position,
// title,url,snippet,domain}], paa?:[], related?:[] }`；`captured`/`raw` 為 Phase 2 / 重解析選配。
model SerpFetch {
  id             String   @id @default(uuid()) @db.Uuid
  normalizedText String   @map("normalized_text")
  keyword        String
  geo            String
  language       String
  device         String? // desktop|mobile（預設 desktop）
  provider       String // serpapi|serper|extension
  results        Json
  captured       Json? // Phase 2：extension 抓取的頁面內容
  raw            Json? // 選配：原始 payload，供日後重解析
  fetchedAt      DateTime @default(now()) @map("fetched_at") @db.Timestamptz

  @@index([geo, language, normalizedText, fetchedAt])
  @@map("serp_fetches")
}

// topic_cluster_runs / topic_clusters / keyword_cluster_assignments（T8.8，Design §16.4，FR-15/18）：
// 主題分群 job 的獨立實體（不複用 KeywordAnalysis）+ 每群命名 + 每字群指派。標準型別（無 pgvector）→ typed
// `prisma.<model>` delegate。群層 intent 與 FR-4 每字 `keyword_intents` **分表互補、不覆寫**（Design §16.1 註）。
model TopicRun {
  id                String         @id @default(uuid()) @db.Uuid
  keywordAnalysisId String         @map("keyword_analysis_id") @db.Uuid
  snapshotId        String         @map("snapshot_id") @db.Uuid
  status            String // queued|running|completed|partial|failed|canceled
  params            Json // embedding+umap+hdbscan+serpEnabled+promptVer+schemaVer
  progress          Json
  idempotencyKey    String         @unique @map("idempotency_key") // hash(snapshot.checksum + canonical params)
  clusterCount      Int?           @map("cluster_count")
  noiseCount        Int?           @map("noise_count")
  error             String?
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz
  clusters          TopicCluster[]

  @@map("topic_cluster_runs")
}

model TopicCluster {
  id                     String   @id @default(uuid()) @db.Uuid
  run                    TopicRun @relation(fields: [runId], references: [id])
  runId                  String   @map("run_id") @db.Uuid
  clusterLabel           Int      @map("cluster_label") // HDBSCAN label（≥0）
  topicName              String   @map("topic_name")
  parentTopic            String   @map("parent_topic")
  intentLabel            String   @map("intent_label") // 群主導意圖（4 值；不覆寫 FR-4 每字 label）
  topicType              String   @map("topic_type")
  reason                 String?
  clusterVolume          BigInt?  @map("cluster_volume") // Σ avgMonthlySearches（null 略過→可能為 null）
  keywordCount           Int      @map("keyword_count")
  confidence             Float?
  representativeKeywords Json     @map("representative_keywords")

  @@index([runId])
  @@map("topic_clusters")
}

model KeywordClusterAssignment {
  runId          String  @map("run_id") @db.Uuid
  normalizedText String  @map("normalized_text")
  clusterId      String? @map("cluster_id") @db.Uuid // null = noise
  confidence     Float // HDBSCAN soft probability
  isNoise        Boolean @map("is_noise")

  @@id([runId, normalizedText])
  @@map("keyword_cluster_assignments")
}

// —— Phase 2 RESERVED（T8.11，Design §16.4；本期僅建表、無 service/邏輯/controller）——
// topic_taxonomy：主題階層樹（FR-20/21 人工整併/鎖定）。self-FK（parent_id → id）。
model TopicTaxonomy {
  id        String          @id @default(uuid()) @db.Uuid
  parentId  String?         @map("parent_id") @db.Uuid
  parent    TopicTaxonomy?  @relation("TopicTaxonomyTree", fields: [parentId], references: [id])
  children  TopicTaxonomy[] @relation("TopicTaxonomyTree")
  level     Int
  status    String // active|locked|noise
  topicName String          @map("topic_name")

  @@index([parentId])
  @@map("topic_taxonomy")
}

// topic_audit_logs：人工校正稽核（FR-19 rename/merge/split/move/lock/mark_noise）。
model TopicAuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  action    String // rename|merge|split|move|lock|mark_noise
  actor     String
  before    Json?
  after     Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("topic_audit_logs")
}

// users：帳號（M10，FR-24）。密碼僅存 argon2id `password_hash`（明文絕不落 DB，S7）。
// session 本體存 Redis（`sess:{sid}`，撤銷=刪 key），不落 DB（Design §17.2）。
model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash") // argon2id
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("users")
}

// M11 追蹤清單與搜量時序（FR-28~30、NFR-16；Design §17.3）。第一天綁 ownerId（FR-27）。
model TrackingList {
  id        String               @id @default(uuid()) @db.Uuid
  ownerId   String?              @map("owner_id") @db.Uuid // FR-27：資源歸屬（nullable、不回填）
  name      String
  geo       String // 固定清單層（語境一致，AC-28.5）
  language  String
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz
  members   TrackingListMember[]

  @@unique([ownerId, name]) // 同 owner 名稱唯一
  @@map("tracking_lists")
}

model TrackingListMember {
  listId         String       @map("list_id") @db.Uuid
  normalizedText String       @map("normalized_text") // 成員 key = 去重/快取同一套（S4）
  text           String // 原字（保留）
  addedAt        DateTime     @default(now()) @map("added_at") @db.Timestamptz
  lastCheckedAt  DateTime?    @map("last_checked_at") @db.Timestamptz // store-on-change 用
  list           TrackingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@id([listId, normalizedText]) // 聯集去重
  @@map("tracking_list_members")
}

// M12 購買歷程分類（T12.5，FR-33 / AC-33.5；Design §17.5）。每字→7 階段之一（strict json_schema + 後處理）。
// **分表互補、不覆寫** `keyword_intents`（S10）：journey stage 與 FR-4 每字 intent 各自獨立持有。
// 快照範疇（snapshotId/analysisId）由呼叫端（T12.6 job）帶入；PK = [snapshotId, normalizedText]（去重同一套）。
model KeywordJourneyAssignment {
  analysisId     String @map("keyword_analysis_id") @db.Uuid
  snapshotId     String @map("snapshot_id") @db.Uuid
  normalizedText String @map("normalized_text") // 成員 key = 去重/快取同一套（S4）
  stage          String // 7 階段 enum 之一（pain_awareness…repurchase_retention）

  @@id([snapshotId, normalizedText])
  @@map("keyword_journey_assignments")
}

// 購買歷程分類 async job 的 run 生命週期（T12.6，FR-33/AC-33.6）。202→GET/SSE/idempotency 契約，仿 TopicRun。
// idempotencyKey = hash(analysisId + snapshotChecksum + canonical(params{schemaVer,deployment}))；bump 版本 → 新 run。
model JourneyRun {
  id                String   @id @default(uuid()) @db.Uuid
  keywordAnalysisId String   @map("keyword_analysis_id") @db.Uuid
  snapshotId        String   @map("snapshot_id") @db.Uuid
  status            String // queued|running|completed|partial|failed|canceled
  params            Json // { schemaVersion, deployment }
  progress          Json
  idempotencyKey    String   @unique @map("idempotency_key")
  keywordCount      Int?     @map("keyword_count")
  error             String?
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([keywordAnalysisId])
  @@map("journey_runs")
}

// 自訂分類定義（T12.7 階段一，FR-34/AC-34.1）。instruction + snapshot 樣本 → LLM 生 labels（待 HITL 確認）；
// 每字→label 指派於階段二（T12.8）落 keyword_custom_assignments。owner 過濾在 service 層（snapshot owner-resolved）。
model CustomClassification {
  id          String   @id @default(uuid()) @db.Uuid
  analysisId  String   @map("keyword_analysis_id") @db.Uuid
  snapshotId  String   @map("snapshot_id") @db.Uuid
  name        String
  instruction String
  labels      Json // [{ label, description }]（HITL 待確認）
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([analysisId])
  @@map("custom_classifications")
}

// 自訂分類階段二歸類結果（T12.8，FR-34/AC-34.3）。每 (classificationId, normalizedText) 一 label（確認集之一，
// 或 sentinel `unclassified`）；snapshot-scoped 物化，view/查詢讀取用，**不覆寫** keyword_intents（S10）。重跑同 cid 覆寫。
model KeywordCustomAssignment {
  classificationId String @map("classification_id") @db.Uuid
  normalizedText   String @map("normalized_text")
  label            String

  @@id([classificationId, normalizedText])
  @@map("keyword_custom_assignments")
}

// 自訂分類階段二 async job 追蹤（T12.8，FR-34/AC-34.2；比照 JourneyRun）。idempotency = sha256(cid+snapshotChecksum+
// labelsHash)——改確認標籤 → labelsHash 變 → 新 run（HITL 正確重跑）；P2002 慢路徑尊重 idempotency（NFR-8 並發）。
model CustomClassifyRun {
  id                String   @id @default(uuid()) @db.Uuid
  classificationId  String   @map("classification_id") @db.Uuid
  keywordAnalysisId String   @map("keyword_analysis_id") @db.Uuid
  snapshotId        String   @map("snapshot_id") @db.Uuid
  status            String // queued|running|completed|failed
  params            Json // { schemaVersion, deployment, labelsHash }
  progress          Json?
  idempotencyKey    String   @unique @map("idempotency_key")
  keywordCount      Int?     @map("keyword_count")
  error             String?
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([classificationId])
  @@index([keywordAnalysisId])
  @@map("custom_classify_runs")
}

// 搜量時序（append-only、store-on-change，AC-29.4）。fetchedAt = 觀測時點（非每日搜量，S1 月粒度）。
model VolumeSnapshot {
  id                 String   @id @default(uuid()) @db.Uuid
  listId             String   @map("list_id") @db.Uuid
  normalizedText     String   @map("normalized_text")
  geo                String
  language           String
  avgMonthlySearches BigInt?  @map("avg_monthly_searches") // null ≠ 0; BIGINT ≥ Ads int64 (mega-term > INT4 max overflows, #469)
  monthlyVolumes     Json     @default("[]") @map("monthly_volumes")
  competition        String?
  competitionIndex   Int?     @map("competition_index")
  cpcLowMicros       BigInt?  @map("cpc_low_micros")
  cpcHighMicros      BigInt?  @map("cpc_high_micros")
  fetchedAt          DateTime @default(now()) @map("fetched_at") @db.Timestamptz

  @@index([listId, normalizedText, fetchedAt])
  @@map("volume_snapshots")
}

// 排程刷新 sweep 的 DB 租約鎖（single-flight，#470/NFR-16；Design §17.3）。sweep 為 append-only + partial
// 韌性（AC-29.5）不可包進單一長交易，故用租約：scheduled job 進場原子搶租約，搶到才 sweep、否則跳過，
// finally 釋放；TTL（TRACKING_SWEEP_LEASE_MS）為 crash 復原上界。單列（固定 name='scheduled-refresh'）。
model TrackingSweepLease {
  name        String   @id
  leasedUntil DateTime @map("leased_until") @db.Timestamptz

  @@map("tracking_sweep_leases")
}

// —— M13 中立資料模型（T13.1，FR-36/37、NFR-17；Design §18.1/18.2/18.3/18.5）——
// 來源無關 ingestion 的分層資料模型（INV-4/5）：raw append-only（captures）→ per-source/per-platform mapper（純函式，
// T13.4）→ canonical 具名表（ai_search_captures / social_posts）。本 task（T13.1）僅落 schema/migration，無 service/
// controller 邏輯：端點（T13.2）、content-hash 去重（T13.3）、mapper 框架（T13.4）、golden fixtures（T13.5）後續填。

// captures：raw 層 append-only（INV-4；FR-36）。所有來源（extension primary / SerpAPI·Threads API reserved）
// 統一先落此表可 reparse；`content_hash` = sha256(canonical(source,schemaVersion,item))＝同來源同內容去重鍵（S16，
// content-hash idempotency 前置，供 T13.3）。`owner_id` 第一天存在（FR-27；機器 x-api-key 來源=null、不回填）。
model Capture {
  id            String   @id @default(uuid()) @db.Uuid
  ownerId       String?  @map("owner_id") @db.Uuid // FR-27：資源歸屬（session→user.id、apiKey→null；nullable、不回填）
  source        String // extension（primary）| serpapi（reserved）| threadsApi（reserved）| merged（S20）
  schemaVersion String   @map("schema_version") // allowlist 驗證（S15，CAPTURE_ACCEPTED_SCHEMA_VERSIONS，T13.3）
  channel       String? // AI 渠道：chatGpt|geminiApp|googleAiMode|googleSearch|aiOverview|aiMode|bingCopilot（S20）
  platform      String? // Social 平台：threads|facebook|dcard|ptt|customDomain（S20）
  contentHash   String   @map("content_hash") // sha256(canonical(source,schemaVersion,item)) 唯一去重鍵（S16）
  payload       Json // 原始 payload（可 reparse；vendor schema 變動只修 mapper + reparse raw，不重抓）
  mapStatus     String   @default("ok") @map("map_status") // ok | partial | failed（AC-37.4；partial 不阻斷同批他筆）
  capturedAt    DateTime @map("captured_at") @db.Timestamptz
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([contentHash]) // 同來源同內容重送去重（content-hash idempotency）
  @@index([source, channel, capturedAt])
  @@map("captures")
}

// brand_profiles：品牌檔案（T14.5，FR-40；Design §18.3）。綁 owner_id（FR-27：session→user.id、apiKey→null；
// nullable、不回填）——owner 過濾唯一強制點在 service 層（S8，非參數繞過）。`name`+`aliases`+`sites` 為本品牌，
// `competitors`=[{name,aliases[],sites[]}]（JSON）；供 AI 可見度分析（FR-42/43）抽取與計數，aliases 聯集正規化
// 比對（`華碩→ASUS`）抽純函式（brand-match.ts，供 FR-42 共用）。同 owner name 唯一（@@unique([ownerId,name]);
// Postgres NULLs distinct → 機器 null-owner 同名不受約束，與 TrackingList 同型；重複→409）。
model BrandProfile {
  id          String   @id @default(uuid()) @db.Uuid
  ownerId     String?  @map("owner_id") @db.Uuid // FR-27：資源歸屬（nullable、不回填）
  name        String // 本品牌名稱（同 owner 內唯一）
  aliases     Json     @default("[]") // 別名/縮寫/拼寫變體（brand-alias-extractor 補全，should）
  sites       Json     @default("[]") // 官網 domain（citations 命中用，FR-43）
  competitors Json     @default("[]") // [{name,aliases[],sites[]}]
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([ownerId, name]) // 同 owner 名稱唯一（重複→409）
  @@map("brand_profiles")
}

// ai_search_captures：AI Search 中立 canonical 骨架（INV-5；Design §18.3）。本 task 僅建表（可讀寫）；
// 分析面（品牌抽取/情緒/媒體分類）與抓取 job（`job_id`→未來 AI Search job）於 M14/M15 逐步填（含 FK/index 補強）。
// `owner_id` 第一天存在（FR-27，與所有 owner 化資源一致；nullable）；`references` 缺 grounding→[]（不編造，§18.3）。
model AiSearchCapture {
  id            String   @id @default(uuid()) @db.Uuid
  ownerId       String?  @map("owner_id") @db.Uuid // FR-27：資源歸屬（nullable、不回填）
  jobId         String   @map("job_id") @db.Uuid // FR-41 抓取 job（M14 補 relation/FK；本骨架僅存 id）
  channel       String // chatGpt|geminiApp|googleAiMode|googleSearch|aiOverview|aiMode|bingCopilot
  query         String
  source        String // extension（primary）| serpapi（reserved）
  schemaVersion String   @map("schema_version")
  blocks        Json // 中立化 text blocks
  references    Json     @default("[]") // [{title,link,snippet?,source?,index}]
  capturedAt    DateTime @map("captured_at") @db.Timestamptz

  @@index([jobId, channel, query])
  @@map("ai_search_captures")
}

// ai_search_runs：AI Search 抓取 job（T14.6，FR-41，INV-3；Design §18.3）——202→GET/SSE/idempotency/partial 契約，
// 仿 journey_runs / custom_classify_runs（fresh top-level input：`id` 即 jobId，非巢狀於既有分析）。`owner_id` 第一天
// 存在（FR-27，nullable、不回填）——owner 過濾唯一強制點在 service 層（S8）。`params`={schemaVersion}；`idempotency_key`
// = sha256(canonical(owner, normalizedKeywords, channels, brandProfileId, params))（同語意→同 run；P2002 慢路徑仲裁並發）。
// `capture_count`=合流落 ai_search_captures 的筆數（partial 時仍記已收筆數）。
model AiSearchRun {
  id             String   @id @default(uuid()) @db.Uuid
  ownerId        String?  @map("owner_id") @db.Uuid // FR-27：資源歸屬（nullable、不回填）
  // T15.8a（#678 G1，Option A additive link）：nullable 連結至 keyword-analysis（standalone M14 用法=null、不破 FR-41）；
  // keyword-analysis 的 `ai_search` feature 由該 analysis 最新 linked run 狀態推導（`aiSearchFeatureStatus`，Design §18.4/S25）。
  keywordAnalysisId String? @map("keyword_analysis_id") @db.Uuid
  status         String // queued|running|completed|partial|failed|canceled
  params         Json // { schemaVersion }
  progress       Json
  idempotencyKey String   @unique @map("idempotency_key")
  captureCount   Int?     @map("capture_count")
  error          String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([keywordAnalysisId]) // owner-scoped 查最新 linked run（feature 推導）
  @@map("ai_search_runs")
}

// social_posts：Social 中立 canonical 骨架（INV-5；Design §18.5）。本 task 僅建表（可讀寫）；多平台 mapper、
// 多來源 merge（`source=merged`）、per-post AI 於 M16/M17 逐步填。`post_key`=normalize(permalink/url)＝跨來源唯一
// 去重鍵（S13，與 capture content-hash 分工）；metrics（likes/comments/reposts/shares）nullable——缺不補 0（S14）。
model SocialPost {
  id            String    @id @default(uuid()) @db.Uuid
  ownerId       String?   @map("owner_id") @db.Uuid // FR-27：資源歸屬（nullable、不回填）
  jobId         String    @map("job_id") @db.Uuid // 爬搜 job（M16 補 relation/FK；本骨架僅存 id）
  platform      String // threads|facebook|dcard|ptt|customDomain（S20）
  postKey       String    @map("post_key") // normalize(permalink/url)＝唯一去重鍵（S13）
  source        String // extension（primary）| threadsApi（reserved）| merged
  author        String? // 公開 PII（NFR-20）
  profileLink   String?   @map("profile_link")
  content       String // 全文（merge 取較長，M16）
  publishedAt   DateTime? @map("published_at") @db.Timestamptz // 中文時間→ISO（mapper 收斂，M16）
  likes         Int? // metrics nullable（S14）：reserved API 來源 null、extension 頁面讀取補
  comments      Int?
  reposts       Int?
  shares        Int?
  schemaVersion String    @map("schema_version")
  capturedAt    DateTime  @map("captured_at") @db.Timestamptz

  @@unique([jobId, postKey]) // 同 job 內同貼文去重（S13）
  @@index([jobId, publishedAt])
  @@map("social_posts")
}

// ai_answers：AI 回答分析結果（T15.5，FR-42；Design §18.4）——`AiSearchCapture`（T14.6 抓取 job 合流落列）經三線
// LLM pipeline（品牌抽取/情緒，T15.2/T15.3）分析後的 per-answer 衍生資料，供 T15.6 `ai_answers` view 讀取。
// `brands`=該回答抽出的品牌提及（canonical names，**刻意不去重＝露出次數**，S17）；`positive`/`negative`=該回答對本品牌
// 的褒/貶累計（**褒貶各自獨立**，S17，不 collapse）。`job_id`=AiSearchRun.id（沿用抓取 job，T15.5 落點決策）；
// re-run 以 job_id clean-slate 保 idempotent（不重複落列）。`schema_version`=AI_VISIBILITY_SCHEMA_VERSION（分析層版本）。
model AiAnswer {
  id            String   @id @default(uuid()) @db.Uuid
  ownerId       String?  @map("owner_id") @db.Uuid // FR-27：資源歸屬（nullable、不回填）
  jobId         String   @map("job_id") @db.Uuid // = AiSearchRun.id（沿用抓取 job 落點）
  channel       String // chatGpt|geminiApp|googleAiMode|googleSearch|aiOverview|aiMode|bingCopilot
  query         String
  answerText    String   @map("answer_text") // 攤平中立化 blocks 文字（ai_answers view 顯示）
  brands        Json     @default("[]") // 品牌提及 canonical names（**不去重＝露出次數**，S17）
  positive      Int      @default(0) // 本品牌褒（各自獨立累計，S17）
  negative      Int      @default(0) // 本品牌貶
  schemaVersion String   @map("schema_version") // AI_VISIBILITY_SCHEMA_VERSION（分析層）
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([jobId, channel])
  @@map("ai_answers")
}

// ai_cited_references：AI 回答引用媒體分類結果（T15.5，FR-42/AC-42.3；Design §18.4）——per reference（domain→9-enum，
// T15.3 media classifier）。供 T15.6 `ai_cited_media`（依 media_type 聚合佔比）+ `ai_cited_pages`（逐頁列表）兩 view 共用
// 同一來源表（DRY）。`domain`=deriveDomain(link)（複用 SERP 線）；`media_type`∈ecommerce/retail/review/news/content/
// blog/social/gov/other（非法/缺→other，不污染，AC-42.5）。job_id clean-slate re-run idempotent。
model AiCitedReference {
  id            String   @id @default(uuid()) @db.Uuid
  ownerId       String?  @map("owner_id") @db.Uuid // FR-27：資源歸屬（nullable、不回填）
  jobId         String   @map("job_id") @db.Uuid // = AiSearchRun.id
  channel       String
  query         String
  link          String
  domain        String // deriveDomain(link)（複用 SERP 線）
  title         String?
  mediaType     String   @map("media_type") // 9-enum（AC-42.3）
  schemaVersion String   @map("schema_version") // AI_VISIBILITY_SCHEMA_VERSION（分析層）
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([jobId, channel])
  @@map("ai_cited_references")
}

// ai_visibility_metrics：AI 可見度指標落庫（T15.5，FR-43；Design §18.4）——`buildAiVisibility`（T15.4 純函式）產出的
// per (channel × dimension × group × brand) `AiVisibilityCell` 攤平落列，供 T15.6 `brand|intent|journey_ai_visibility`
// （依 dimension 過濾）+ `*_summary`（聚合 KPI）view 讀取。`share_of_voice`=品牌提及÷全品牌提及總數（**分母 0→null**，
// AC-43.2；分子 0 分母>0→真實 0）；`exposure`=範疇關鍵字 avgMonthlySearches 加總（**任一 null 不補 0、全缺→null**，
// AC-43.1）。ratio/exposure 用 double（Float）避溢位、承 number|null 語意。job_id clean-slate re-run idempotent。
model AiVisibilityMetric {
  id            String   @id @default(uuid()) @db.Uuid
  ownerId       String?  @map("owner_id") @db.Uuid // FR-27：資源歸屬（nullable、不回填）
  jobId         String   @map("job_id") @db.Uuid // = AiSearchRun.id
  channel       String
  dimension     String // keyword | intent | journey（AC-43.3）
  groupKey      String   @map("group_key") // 分組值：keyword 文字 / 意圖主題 / 購買歷程主題（"group" 為 SQL 保留字→改名）
  brand         String
  mentions      Int // 露出次數（**不去重**，S17）
  shareOfVoice  Float?   @map("share_of_voice") // 分母 0→null（AC-43.2）；分子 0 分母>0→0
  citations     Int // references 命中 BrandProfile.sites/domain 次數
  exposure      Float? // avgMonthlySearches 加總（null 不補 0、全缺→null）
  schemaVersion String   @map("schema_version") // AI_VISIBILITY_SCHEMA_VERSION（分析層）
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([jobId, dimension, channel])
  @@map("ai_visibility_metrics")
}
